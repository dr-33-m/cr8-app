# B.L.A.Z.E AI Agent Configuration
OPENROUTER_API_KEY=
AI_PROVIDER=
OLLAMA_BASE_URL=
AI_MODEL_NAME=

# Blender Configuration
# Path to the Blender executable (required for local mode)
BLENDER_EXECUTABLE_PATH=

# Deployment Mode: "local" (subprocess) or "remote" (VastAI)
LAUNCH_MODE=local

# VastAI Configuration (required when LAUNCH_MODE=remote)
# See TEMPLATE_SETUP.md for how to create the template
# API key from https://console.vast.ai/account/
VASTAI_API_KEY=
# Template hash ID from https://cloud.vast.ai/templates/ (bundles image, onstart, env vars, SSH)
# This is the hash_id string (e.g., "4e17788f74f075dd9aab7d0d4427968f"), not the numeric ID
VASTAI_TEMPLATE_HASH_ID=
# SSH keys are generated automatically at startup and attached via VastAI API
# Max concurrent Blender processes per VastAI instance
MAX_USERS_PER_INSTANCE=3
# Seconds to keep an empty instance alive before destroying it
INSTANCE_IDLE_TIMEOUT=300

# PostgreSQL Database (required for remote mode)
# Uses asyncpg driver for async SQLAlchemy
DATABASE_URL=postgresql+asyncpg://cr8:password@localhost:5432/cr8
